# Environment Configuration - Example

# General Settings
PORT=5001
CLIENT_URL=http://localhost:5173

# Database Settings
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname?appName=AppName
MONGODB_URI=

# Security
# JWT_SECRET=your-long-random-secret-here
JWT_SECRET=
JWT_EXPIRES_IN=7d
# ENCRYPTION_KEY=32_byte_hex_string
ENCRYPTION_KEY=

# Google Cloud Platform (OAuth 2.0)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=

# Facebook/Meta Developer
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:5001/api/auth/facebook/callback

# AI Engine (Google Gemini)
GEMINI_API_KEY=

# Email Services (Resend or Gmail)
RESEND_API_KEY=
EMAIL_FROM=
GMAIL_APP_PASSWORD=

# Administration
SUPER_ADMIN_EMAIL=
GCP_METADATA_TIMEOUT=0

# Redis Configuration
# Use REDIS_URL for Redis Cloud or other hosted services
# Example: redis://default:password@host:port
REDIS_URL=
# Or use individual variables
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
QUEUE_CONCURRENCY=10
